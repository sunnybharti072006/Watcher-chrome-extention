{
  "manifest_version": 3,
  "name": "WATCHER — Neural URL Tracker",
  "version": "1.0.0",
  "description": "Track any public URL. Get email/SMS alerts when anything changes.",

  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "contextMenus"
  ],

  "host_permissions": [
    "http://localhost:6060/*",
    "https://*/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}